{
  "name": "measured",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "node scripts/install-git-hooks.mjs",
    "backfill:workout-measurement-analysis": "tsx scripts/backfill-workout-measurement-analysis.ts",
    "build:data": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/build-workouts-data.ts",
    "diagnose:workout-sources": "tsx scripts/diagnose-workout-sources.ts",
    "import:apple-health": "tsx scripts/import-apple-health-export.ts",
    "serve:apple-health-sync": "tsx scripts/run-apple-health-sync-server.ts",
    "migrate:workout-notes:json": "tsx scripts/migrate-workout-notes-to-json.ts",
    "check:pre-commit": "pnpm exec tsc -p tsconfig.app.json --noEmit && pnpm exec tsc -p tsconfig.node.json --noEmit",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "link:workout-source": "tsx scripts/link-workout-source.ts",
    "sync:strava": "uv run python scripts/sync-strava-cache.py --with-streams",
    "vercel:link": "pnpm dlx vercel link",
    "deploy:vercel:preview": "pnpm dlx vercel build && pnpm dlx vercel deploy --prebuilt --archive=tgz",
    "deploy:vercel:prod": "pnpm dlx vercel build --prod && pnpm dlx vercel deploy --prebuilt --prod --archive=tgz",
    "predev": "pnpm run build:data",
    "pretypecheck": "pnpm run build:data",
    "pretest": "pnpm run build:data",
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "katex": "^0.16.27",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "^3.11.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cli-progress": "^3.12.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
